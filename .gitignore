## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/
TensorSharp.GGML.Native/build/
TensorSharp.GGML.Native/build-windows/

# ggml sources are cloned at build time from https://github.com/ggml-org/ggml
# (see eng/fetch-ggml.sh / eng/fetch-ggml.ps1), not committed.
ExternalProjects/.ggml-fetch.lock
ExternalProjects/.ggml-fetch.lock.d/
ExternalProjects/ggml/

# Portable Vulkan build toolchain (headers, loader import lib, glslc), provisioned
# at build time by eng/fetch-vulkan-toolchain.ps1 when no Vulkan SDK is installed.
ExternalProjects/vulkan-toolchain/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# IDE/build caches
*.csproj.lscache

# Benchmark tooling artifacts
benchmarks/engine_comparison/__pycache__/
benchmarks/engine_comparison/results/
