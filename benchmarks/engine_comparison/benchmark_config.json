  "scenarios": {
    "text_short": {"kind": "text", "description": "Short single-turn text prompt", "max_tokens": 128},
    "text_long": {"kind": "text", "description": "Long-context single-turn text prompt (~1k tokens in)", "max_tokens": 128},
    "multi_turn": {"kind": "multi_turn", "description": "3-turn conversation, timed on the final turn", "max_tokens": 128},
    "function_call": {"kind": "function_call", "description": "Tool/function-calling (get_weather)", "max_tokens": 128},
    "json_mode": {"kind": "json_mode", "description": "Structured output (response_format json_object)", "max_tokens": 128},
    "image": {"kind": "image", "description": "Image understanding (test.jpg)", "modality": "image", "max_tokens": 128},
    "audio": {"kind": "audio", "description": "Audio understanding (~45 s speech)", "modality": "audio", "max_tokens": 128},
    "video": {"kind": "video", "description": "Video understanding (sampled frames)", "modality": "video", "max_tokens": 128},

    "prefill_2k": {"kind": "text", "description": "Prefill throughput @ ~2k prompt tokens (sliced from prefill_corpus.txt)", "max_tokens": 8},
    "prefill_4k": {"kind": "text", "description": "Prefill throughput @ ~4k prompt tokens (sliced from prefill_corpus.txt)", "max_tokens": 8},
    "prefill_8k": {"kind": "text", "description": "Prefill throughput @ ~8k prompt tokens (sliced from prefill_corpus.txt)", "max_tokens": 8},
    "prefill_16k": {"kind": "text", "description": "Prefill throughput @ ~16k prompt tokens (sliced from prefill_corpus.txt)", "max_tokens": 8}
  },

  "engines": {
    "tensorsharp": {"display": "TensorSharp", "transport": "server", "backends": ["gpu", "cpu"]},
    "llamacpp": {"display": "llama.cpp", "transport": "server", "backends": ["gpu", "cpu"]},
    "vllm": {"display": "vLLM", "transport": "connect", "backends": ["gpu"]}
  },

  "backends": ["gpu", "cpu"],

  "maps": {
    "tensorsharp_backend": {"gpu": "ggml_cuda", "cpu": "cpu"},
    "llama_ngl": {"gpu": 999, "cpu": 0}
  },

  "llama": {
    "context_size": 24576,
    "extra_args": ["--jinja"]
  },

  "ready_timeout_s": {"small": 600, "medium": 900, "large": 1200},

  "defaults": {
    "engines": ["tensorsharp", "llamacpp", "vllm"],
    "models": ["gemma4-e4b", "gemma4-12b", "gemma4-26b-a4b", "qwen36-35b-a3b", "qwen36-35b-a3b-q4", "diffusiongemma"],
    "scenarios": ["text_short", "text_long", "multi_turn", "function_call", "json_mode", "image", "audio", "video", "prefill_2k", "prefill_4k", "prefill_8k"],
    "backends": ["gpu", "cpu"],
    "mtp_modes": [false],
    "concurrency": [1],
    "max_tokens": 128,
    "warmup": 1,
    "server_max_tokens": 512
  }
}
