{
  // Gemma-4 26B-A4B (QAT UD-Q4_K_XL) — Mixture-of-Experts multimodal LLM
  // (~14 GB, ~4B active params) with its vision projector and MTP draft head.
  // Run with:
  //   TensorSharp.Cli    --config config/gemma-4-26b-a4b.json --image photo.png
  //   TensorSharp.Server --config config/gemma-4-26b-a4b.json
  "variables": {
    "modelRoot": "C:/Works/models"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  "temperature": 1.0,
  "top-k": 64,
  "top-p": 0.95,

  "model": "${modelRoot}/gemma-4-26B-A4B-it-qat-UD-Q4_K_XL.gguf",
  "mmproj": "${modelRoot}/gemma-4-26B-A4B-mmproj-BF16.gguf",

  // MTP speculative decoding (server only): separate draft GGUF, lossless.
  "mtp-spec": false,
  "mtp-draft-model": "${modelRoot}/gemma-4-26B-A4B-it-Q4_0-MTP.gguf"
}
