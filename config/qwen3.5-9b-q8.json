{
  // Qwen3.5-9B (Q8_0) — dense text LLM, highest-quality local quant (~8.9 GB).
  // Run with:
  //   TensorSharp.Cli    --config config/qwen3.5-9b-q8.json --input prompt.txt
  //   TensorSharp.Server --config config/qwen3.5-9b-q8.json
  // Command-line options override anything here (e.g. --backend ggml_vulkan).
  "variables": {
    "modelRoot": "C:/Works/models"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  // Qwen3's recommended sampling for non-thinking generation.
  "temperature": 0.7,
  "top-k": 20,
  "top-p": 0.8,
  "min-p": 0,

  "model": "${modelRoot}/Qwen3.5-9B-Q8_0.gguf"
}
