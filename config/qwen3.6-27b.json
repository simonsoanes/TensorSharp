{
  // Qwen3.6-27B (UD-IQ2_XXS) — dense multimodal LLM (~9.6 GB) plus its
  // vision projector, so it can read images. The trunk + mmproj are co-located
  // under ${modelRoot}/mtp.
  // Run with:
  //   TensorSharp.Cli    --config config/qwen3.6-27b.json --image photo.png
  //   TensorSharp.Server --config config/qwen3.6-27b.json
  "variables": {
    "modelRoot": "C:/Works/models",
    "root": "C:/Works/models/mtp"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  "temperature": 0.7,
  "top-k": 20,
  "top-p": 0.8,
  "min-p": 0,

  "model": "${root}/Qwen3.6-27B-UD-IQ2_XXS.gguf",
  "mmproj": "${root}/Qwen3.6-27B-mmproj-BF16.gguf"

  // MTP speculative decoding: Qwen3.6 embeds its NextN draft head in the trunk
  // GGUF, so no separate draft file is needed — enable it (server only) with:
  //   "mtp-spec": true
  // It is lossless (verify step guarantees identical output); whether it is
  // faster than plain decode depends on the workload, so measure before pinning.
}
