{
  // Gemma-4 12B (QAT UD-Q4_K_XL) — dense multimodal LLM (~6.7 GB, QAT-lossless
  // 4-bit) with its vision projector and MTP draft head. All three files live
  // under ${modelRoot}/gemma_mtp/qat.
  // Run with:
  //   TensorSharp.Cli    --config config/gemma-4-12b.json --image photo.png
  //   TensorSharp.Server --config config/gemma-4-12b.json
  "variables": {
    "root": "C:/Works/models/gemma_mtp/qat"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  "temperature": 1.0,
  "top-k": 64,
  "top-p": 0.95,

  "model": "${root}/gemma-4-12B-it-qat-UD-Q4_K_XL.gguf",
  "mmproj": "${root}/gemma-4-12B-mmproj-BF16.gguf",

  // MTP speculative decoding (server only): separate draft GGUF, lossless.
  "mtp-spec": true,
  "mtp-draft-model": "${root}/gemma-4-12B-it-Q4_0-MTP.gguf"
}
