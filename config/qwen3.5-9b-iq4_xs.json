{
  // Qwen3.5-9B (IQ4_XS) — same model as qwen3.5-9b-q8 but a smaller ~5.2 GB
  // quant that fits comfortably on 8 GB GPUs, at a small quality cost.
  // Run with:
  //   TensorSharp.Cli    --config config/qwen3.5-9b-iq4_xs.json --input prompt.txt
  //   TensorSharp.Server --config config/qwen3.5-9b-iq4_xs.json
  "variables": {
    "modelRoot": "C:/Works/models"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  "temperature": 0.7,
  "top-k": 20,
  "top-p": 0.8,
  "min-p": 0,

  "model": "${modelRoot}/Qwen3.5-9B-IQ4_XS.gguf"
}
