{
  // Qwen3.5-9B Uncensored (HauhauCS-Aggressive, Q8_0) — dense text LLM, an
  // uncensored/abliterated Qwen3.5-9B fine-tune (~8.9 GB).
  // Run with:
  //   TensorSharp.Cli    --config config/qwen3.5-9b-uncensored-q8.json --input prompt.txt
  //   TensorSharp.Server --config config/qwen3.5-9b-uncensored-q8.json
  "variables": {
    "modelRoot": "C:/Works/models"
  },

  "backend": "ggml_cuda",
  "max-tokens": 4096,
  "continuous-batching": true,

  "temperature": 0.7,
  "top-k": 20,
  "top-p": 0.8,
  "min-p": 0,
  // This aggressive fine-tune enters a long-form paragraph attractor at 1.0
  // (disabled) in both TensorSharp and llama.cpp. Keep a modest safety penalty.
  "repeat-penalty": 1.1,
  "repeat-last-n": 64,

  "model": "${modelRoot}/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q8_0.gguf"
}
